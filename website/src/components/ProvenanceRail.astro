---
/**
 * ProvenanceRail — an honest static sidebar on the landing page.
 *
 * This is NOT a live analysis tool. It shows static, build-time facts
 * about the compiler and website (version, target, example count).
 * The live typed-transition provenance demo lives in /playground,
 * where the WASM compiler actually runs.
 *
 * Previously this component had an "example view" that showed
 * precompiled actions/types/consume-create sets with effect-class
 * labels (Mutating/Creating/etc). That was theatre: the data was
 * static JSON from build time, but the presentation implied the page
 * was analyzing code in real time. Removed.
 */
import { translations, defaultLocale } from "../i18n/translations";
import { provenanceByExample } from "../lib/provenance";

const t = translations[defaultLocale];
const examples = Object.entries(provenanceByExample);
const version = examples[0]?.[1].compilerVersion ?? "—";
const target = examples[0]?.[1].target ?? "ckb";
---

<aside class="provenance-rail" data-provenance-rail aria-label={t.provenance.label}>
  <div class="rail-header">
    <span class="rail-label" data-i18n="provenance.label">{t.provenance.label}</span>
    <button class="rail-close" type="button" data-rail-close aria-label="Close" hidden>
      <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 5l10 10M15 5L5 15" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
    </button>
  </div>

  <div class="rail-body">
    <dl class="rail-facts">
      <div class="rail-fact">
        <dt data-i18n="provenance.version">{t.provenance.version}</dt>
        <dd class="substrate-value">v{version}</dd>
      </div>
      <div class="rail-fact">
        <dt data-i18n="provenance.target">{t.provenance.target}</dt>
        <dd>{target}</dd>
      </div>
      <div class="rail-fact">
        <dt data-i18n="provenance.examples">{t.provenance.examples}</dt>
        <dd class="substrate-value">{examples.length}</dd>
      </div>
    </dl>

    <div class="rail-cta">
      <p class="rail-cta-text" data-i18n="provenance.ctaText">{t.provenance.ctaText}</p>
      <a class="rail-cta-link" href="/playground" data-i18n="provenance.ctaLink">{t.provenance.ctaLink}</a>
    </div>
  </div>
</aside>

<button class="rail-toggle" type="button" data-rail-toggle aria-label={t.provenance.label} aria-expanded="false">
  <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 6h12M4 10h12M4 14h12" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
</button>

<style>
  .provenance-rail {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 248px;
    z-index: 80;
    display: none;
    flex-direction: column;
    border-left: 1px solid var(--substrate-rule);
    background: var(--substrate-bg);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  /* Desktop: persistent rail */
  @media (min-width: 1100px) {
    .provenance-rail {
      display: flex;
    }

    .rail-toggle {
      display: none;
    }
  }

  .rail-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 80px 18px 12px;
    border-bottom: 1px solid var(--substrate-rule);
  }

  .rail-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--substrate-dim);
  }

  .rail-close {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--substrate-dim);
    cursor: pointer;
  }

  .rail-close svg {
    width: 16px;
    height: 16px;
  }

  .rail-body {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 14px 18px 24px;
    display: flex;
    flex-direction: column;
  }

  .rail-facts {
    margin: 0 0 24px;
  }

  .rail-fact {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
    padding: 7px 0;
  }

  .rail-fact dt {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--substrate-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .rail-fact dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--substrate-text);
  }

  .substrate-value {
    color: var(--substrate-accent);
    font-weight: 600;
  }

  .rail-cta {
    margin-top: auto;
    padding: 16px;
    border: 1px solid var(--substrate-rule);
    border-radius: 8px;
    background: var(--panel-soft);
  }

  .rail-cta-text {
    margin: 0 0 10px;
    font-size: 0.74rem;
    line-height: 1.5;
    color: var(--substrate-dim);
  }

  .rail-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
  }

  .rail-cta-link::after {
    content: "→";
  }

  .rail-cta-link:hover {
    text-decoration: underline;
  }

  /* Mobile: slide-over drawer toggle */
  .rail-toggle {
    position: fixed;
    right: 16px;
    bottom: 72px;
    z-index: 81;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--line-soft);
    border-radius: 50%;
    background: var(--surface-button);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--text);
    cursor: pointer;
    box-shadow: var(--shadow-soft);
  }

  .rail-toggle[aria-expanded="true"] {
    display: none;
  }

  .rail-toggle svg {
    width: 20px;
    height: 20px;
  }

  @media (max-width: 1099px) {
    .provenance-rail {
      transform: translateX(100%);
      transition: transform 0.3s var(--ease-standard);
    }

    .provenance-rail[data-open] {
      transform: translateX(0);
    }

    .rail-close[hidden] {
      display: inline-flex !important;
    }
  }
</style>

<script>
  const rail = document.querySelector<HTMLElement>("[data-provenance-rail]");
  const toggle = document.querySelector<HTMLButtonElement>("[data-rail-toggle]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-rail-close]");

  const setOpen = (open: boolean) => {
    if (!rail || !toggle) return;
    if (open) {
      rail.setAttribute("data-open", "");
      toggle.setAttribute("aria-expanded", "true");
    } else {
      rail.removeAttribute("data-open");
      toggle.setAttribute("aria-expanded", "false");
    }
  };

  toggle?.addEventListener("click", () => setOpen(true));
  closeBtn?.addEventListener("click", () => setOpen(false));
</script>
