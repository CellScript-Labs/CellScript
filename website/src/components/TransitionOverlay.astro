---
/**
 * TransitionOverlay — the typed-transition navigation metaphor.
 *
 * When the user scrolls into a new section (or clicks a section anchor),
 * a single mono line flashes at the bottom of the screen showing the
 * transition as a CellScript-style action:
 *
 *   action: view_model · consume [workflow] → create [model] · effect: Pure
 *
 * This lets the site self-teach CellScript's core primitive: every
 * navigation is framed as consuming the previous view and creating the
 * next one. The last section (getting-started) uses `Mutating` as a
 * small conceit — "starting to use" is the only state-changing action.
 *
 * Behaviour:
 *  - IntersectionObserver fires once per section entry.
 *  - 400ms fade in, 1200ms hold, 400ms fade out (2s total).
 *  - prefers-reduced-motion: hidden entirely.
 *  - aria-live="polite" so screen readers announce context.
 *
 * The caption map is data-driven via `data-transition` attributes on
 * each <section>, so the component stays generic.
 */
---

<div
  class="transition-overlay"
  role="status"
  aria-live="polite"
  aria-atomic="true"
  data-transition-overlay
  hidden
>
  <code class="transition-caption" data-transition-caption></code>
</div>

<style>
  .transition-overlay {
    position: fixed;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    z-index: 90;
    max-width: min(90vw, 640px);
    padding: 10px 18px;
    border: 1px solid var(--substrate-rule);
    border-radius: var(--radius);
    background: var(--substrate-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: var(--shadow-soft);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s var(--ease-standard);
  }

  .transition-overlay[data-visible] {
    opacity: 1;
  }

  .transition-caption {
    display: block;
    color: var(--substrate-text);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.5;
    letter-spacing: 0.01em;
    text-align: center;
  }

  /* The action name is the only coloured token — green for Pure,
     orange for Mutating, matching the substrate palette. */
  .transition-caption :global(.t-action) {
    color: var(--accent);
    font-weight: 600;
  }

  .transition-caption :global(.t-effect-mutating) {
    color: var(--substrate-accent);
    font-weight: 600;
  }

  .transition-caption :global(.t-effect-pure) {
    color: var(--accent);
    font-weight: 600;
  }

  .transition-caption :global(.t-dim) {
    color: var(--substrate-dim);
  }

  @media (max-width: 600px) {
    .transition-overlay {
      bottom: 12px;
      max-width: calc(100vw - 24px);
      padding: 8px 14px;
    }

    .transition-caption {
      font-size: 0.66rem;
    }
  }

  /* Respect reduced motion: hide the overlay entirely. The section
     name in the nav already orients the user. */
  @media (prefers-reduced-motion: reduce) {
    .transition-overlay {
      display: none;
    }
  }
</style>

<script>
  type SectionTransition = {
    action: string;
    consume: string;
    create: string;
    effect: string;
  };

  const overlay = document.querySelector<HTMLElement>("[data-transition-overlay]");
  const caption = document.querySelector<HTMLElement>("[data-transition-caption]");
  if (overlay && caption) {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let hideTimer: number | undefined;

    const show = (raw: string) => {
      if (reduceMotion) return;
      let tr: SectionTransition;
      try {
        tr = JSON.parse(raw);
      } catch {
        return;
      }
      // Colour the action name and effect class for visual anchoring.
      const escapedAction = tr.action.replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c] as string));
      const effectClass = tr.effect === "Mutating" ? "t-effect-mutating" : "t-effect-pure";
      const consume = tr.consume === "[]" ? "[]" : `[${tr.consume}]`;
      caption.innerHTML =
        `<span class="t-dim">action:</span> <span class="t-action">${escapedAction}</span>` +
        ` <span class="t-dim">· consume</span> ${consume}` +
        ` <span class="t-dim">→ create</span> [${tr.create}]` +
        ` <span class="t-dim">· effect:</span> <span class="${effectClass}">${tr.effect}</span>`;

      overlay.removeAttribute("hidden");
      // Force reflow so the transition runs on the first show.
      void overlay.offsetWidth;
      overlay.setAttribute("data-visible", "");

      window.clearTimeout(hideTimer);
      hideTimer = window.setTimeout(() => {
        overlay.removeAttribute("data-visible");
        // Hide from AT after the fade completes.
        window.setTimeout(() => overlay.setAttribute("hidden", ""), 400);
      }, 1600);
    };

    const sections = Array.from(document.querySelectorAll<HTMLElement>("[data-transition]"));
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && entry.intersectionRatio >= 0.4) {
            const raw = entry.target.getAttribute("data-transition");
            if (raw) show(raw);
          }
        }
      },
      { threshold: [0.4] },
    );
    sections.forEach((section) => observer.observe(section));
  }
</script>
