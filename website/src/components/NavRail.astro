---
/**
 * NavRail — the unified sidebar chrome shared by / and /playground.
 *
 * Replaces the topbar entirely. Contains:
 *  - Brand logo + wordmark (links home)
 *  - Theme toggle (light/dark) + language toggle (en/zh)
 *  - Page navigation: Overview, Registry, Playground (active state per page)
 *  - Resource links: Docs, Wiki, Source
 *  - Community: discussion thread, website feedback
 *  - GitHub Activity: recent releases + commits (build-time fetched)
 *
 * The `page` prop ("home" | "registry" | "playground") controls which nav item is
 * highlighted as active, so switching pages feels continuous.
 *
 * Desktop (>=1100px): persistent 320px right rail.
 * Mobile (<1100px): slide-over drawer with floating toggle button.
 */
import { translations, defaultLocale } from "../i18n/translations";
import githubActivity from "../data/github-activity.json";

interface Props {
  page?: "home" | "registry" | "playground";
}

const { page = "home" } = Astro.props;
const t = translations[defaultLocale];
const ext = {
  wiki: "https://github.com/a19q3/CellScript/wiki",
  community: "https://talk.nervos.org/t/cellscript-a-dsl-for-cell-based-contracts/10193/9",
  websiteFeedback: "https://talk.nervos.org/t/cellscript-website-v0-is-live/10403/2",
  source: "https://github.com/a19q3/CellScript",
  docs: "https://github.com/a19q3/CellScript/tree/main/docs",
  releases: "https://github.com/a19q3/CellScript/releases",
  commits: "https://github.com/a19q3/CellScript/commits/main",
};

const releases = (githubActivity as { releases: any[] }).releases;
const commits = (githubActivity as { commits: any[] }).commits;
---

<!-- Inline theme init: runs before paint to prevent FOUC -->
<script is:inline>
  (function () {
    try {
      var theme = localStorage.getItem("cellscript-theme");
      if (!theme) theme = window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
      document.documentElement.dataset.theme = theme;
    } catch (e) {}
  })();
</script>

<aside class="nav-rail" data-nav-rail aria-label={t.navRail.title}>
  <!-- Brand + controls -->
  <div class="rail-brand-bar">
    <a class="rail-brand" href="/" aria-label={t.nav.home}>
      <span class="brand-mark" aria-hidden="true"></span>
      <span>CellScript</span>
    </a>
    <div class="rail-controls">
      <button class="rail-ctrl-btn" type="button" aria-label={t.language.aria} data-language-toggle title={t.language.aria}>
        <span data-language-label>{t.language.switchTo}</span>
      </button>
      <button class="rail-ctrl-btn rail-theme-btn" type="button" aria-label={t.theme.switchToDark} aria-pressed="false" data-theme-toggle title={t.theme.switchToDark}>
        <svg class="icon-dark" viewBox="0 0 20 20" aria-hidden="true"><path d="M15 12a6 6 0 0 1-8-8 6 6 0 1 0 8 8z" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
        <svg class="icon-light" viewBox="0 0 20 20" aria-hidden="true"><circle cx="10" cy="10" r="3.5" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.2 4.2l1.4 1.4M14.4 14.4l1.4 1.4M15.8 4.2l-1.4 1.4M5.6 14.4l-1.4 1.4" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
      </button>
      <button class="rail-ctrl-btn rail-close-btn" type="button" data-rail-close aria-label="Close" hidden>
        <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 5l10 10M15 5L5 15" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
      </button>
    </div>
  </div>

  <div class="rail-body">
    <!-- Page navigation -->
    <nav class="rail-section" aria-label={t.navRail.links}>
      <ul class="rail-pages">
        <li>
          <a href="/" class:list={["rail-page-item", page === "home" && "active"]}>
            <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3 10l7-6 7 6v7H3z" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M8 17v-5h4v5" fill="none" stroke="currentColor" stroke-width="1.4"/></svg>
            <span>{defaultLocale === "en" ? "Overview" : "总览"}</span>
          </a>
        </li>
        <li>
          <a href="/playground" class:list={["rail-page-item", page === "playground" && "active"]}>
            <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3 5.5h14v9H3z" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M7 8.5l-2 1.5 2 1.5M13 8.5l2 1.5-2 1.5" fill="none" stroke="currentColor" stroke-width="1.4"/></svg>
            <span>Playground</span>
          </a>
        </li>
        <li>
          <a href="/registry" class:list={["rail-page-item", page === "registry" && "active"]}>
            <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 6.5 10 3l6 3.5v7L10 17l-6-3.5z" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M4 6.5 10 10l6-3.5M10 10v7" fill="none" stroke="currentColor" stroke-width="1.4"/></svg>
            <span data-i18n="nav.registry">{t.nav.registry}</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Resources -->
    <div class="rail-section">
      <span class="rail-section-label" data-i18n="navRail.links">{t.navRail.links}</span>
      <ul class="rail-links">
        <li>
          <a href={ext.docs} target="_blank" rel="noopener noreferrer" class="rail-link-item">
            <span class="rail-link-name" data-i18n="navRail.docs">{t.navRail.docs}</span>
            <span class="rail-link-desc" data-i18n="navRail.docsDesc">{t.navRail.docsDesc}</span>
          </a>
        </li>
        <li>
          <a href={ext.wiki} target="_blank" rel="noopener noreferrer" class="rail-link-item">
            <span class="rail-link-name" data-i18n="navRail.wiki">{t.navRail.wiki}</span>
            <span class="rail-link-desc" data-i18n="navRail.wikiDesc">{t.navRail.wikiDesc}</span>
          </a>
        </li>
        <li>
          <a href={ext.source} target="_blank" rel="noopener noreferrer" class="rail-link-item">
            <span class="rail-link-name" data-i18n="navRail.source">{t.navRail.source}</span>
            <span class="rail-link-desc" data-i18n="navRail.sourceDesc">{t.navRail.sourceDesc}</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- Community -->
    <div class="rail-section">
      <span class="rail-section-label" data-i18n="navRail.community">{t.navRail.community}</span>
      <ul class="rail-links">
        <li>
          <a href={ext.community} target="_blank" rel="noopener noreferrer" class="rail-link-item">
            <span class="rail-link-name" data-i18n="navRail.community">{t.navRail.community}</span>
            <span class="rail-link-desc" data-i18n="navRail.communityDesc">{t.navRail.communityDesc}</span>
          </a>
        </li>
        <li>
          <a href={ext.websiteFeedback} target="_blank" rel="noopener noreferrer" class="rail-link-item">
            <span class="rail-link-name" data-i18n="navRail.websiteFeedback">{t.navRail.websiteFeedback}</span>
            <span class="rail-link-desc" data-i18n="navRail.websiteFeedbackDesc">{t.navRail.websiteFeedbackDesc}</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- GitHub Activity: Releases -->
    {releases.length > 0 && (
      <div class="rail-section">
        <div class="rail-section-head">
          <span class="rail-section-label" data-i18n="navRail.releases">{t.navRail.releases}</span>
          <a href={ext.releases} target="_blank" rel="noopener noreferrer" class="rail-view-all" data-i18n="navRail.viewAll">{t.navRail.viewAll}</a>
        </div>
        <ul class="rail-activity">
          {releases.map((r) => (
            <li>
              <a href={r.url} target="_blank" rel="noopener noreferrer" class="rail-activity-item">
                <div class="rail-activity-head">
                  <code class="rail-activity-tag">{r.tag}</code>
                  <time class="rail-activity-date">{r.date}</time>
                </div>
                <p class="rail-activity-body">{r.body}</p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- GitHub Activity: Commits -->
    {commits.length > 0 && (
      <div class="rail-section">
        <div class="rail-section-head">
          <span class="rail-section-label" data-i18n="navRail.commits">{t.navRail.commits}</span>
          <a href={ext.commits} target="_blank" rel="noopener noreferrer" class="rail-view-all" data-i18n="navRail.viewAll">{t.navRail.viewAll}</a>
        </div>
        <ul class="rail-activity rail-commits">
          {commits.map((c) => (
            <li>
              <a href={c.url} target="_blank" rel="noopener noreferrer" class="rail-commit-item">
                <code class="rail-commit-sha">{c.sha}</code>
                <span class="rail-commit-msg">{c.message}</span>
                <time class="rail-activity-date">{c.date}</time>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</aside>

<button class="rail-toggle" type="button" data-rail-toggle aria-label={t.navRail.title} aria-expanded="false">
  <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 6h12M4 10h12M4 14h12" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
</button>

<style>
  .nav-rail {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 320px;
    z-index: 80;
    display: none;
    flex-direction: column;
    border-left: 1px solid var(--substrate-rule);
    background: var(--substrate-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  @media (min-width: 1100px) {
    .nav-rail { display: flex; }
    .rail-toggle { display: none; }
  }

  /* ---- Brand bar ---- */
  .rail-brand-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 20px 20px 16px;
    border-bottom: 1px solid var(--substrate-rule);
  }

  .rail-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--text);
    text-decoration: none;
  }

  .rail-brand :global(.brand-mark) {
    width: 22px;
    height: 22px;
    border: 1px solid var(--accent);
    border-radius: 6px;
    position: relative;
    background: var(--brand-mark-bg);
    flex-shrink: 0;
  }
  .rail-brand :global(.brand-mark)::before,
  .rail-brand :global(.brand-mark)::after {
    content: "";
    position: absolute;
    inset: 5px;
    border: 1px solid var(--brand-mark-inner);
    border-radius: 4px;
  }
  .rail-brand :global(.brand-mark)::after {
    inset: 8px;
    border-color: var(--accent);
  }

  .rail-controls {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .rail-ctrl-btn {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    min-height: 36px;
    padding: 0 8px;
    border: 1px solid transparent;
    border-radius: 7px;
    background: transparent;
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.76rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard);
  }
  .rail-ctrl-btn:hover {
    color: var(--text);
    border-color: var(--line-soft);
    background: var(--surface-hover);
  }
  .rail-ctrl-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }

  .rail-theme-btn .icon-light { display: none; }
  :global([data-theme="light"]) .rail-theme-btn .icon-dark { display: none; }
  :global([data-theme="light"]) .rail-theme-btn .icon-light { display: inline-flex; }
  .rail-theme-btn svg { width: 18px; height: 18px; }

  .rail-close-btn { display: none; }

  /* ---- Body ---- */
  .rail-body {
    flex: 1 1 auto;
    overflow-y: auto;
  }

  .rail-section {
    padding: 16px 20px;
    border-bottom: 1px solid var(--substrate-rule);
  }
  .rail-section:last-child { border-bottom: none; }

  .rail-section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 10px;
  }

  .rail-section-label {
    display: block;
    margin-bottom: 10px;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--substrate-dim);
  }
  .rail-section-head .rail-section-label { margin-bottom: 0; }

  .rail-view-all {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    color: var(--accent);
    text-decoration: none;
  }
  .rail-view-all:hover { text-decoration: underline; }

  /* ---- Page nav ---- */
  .rail-pages {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .rail-page-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard);
  }
  .rail-page-item:hover {
    color: var(--text);
    background: var(--surface-hover);
  }
  .rail-page-item.active {
    color: var(--accent);
    background: var(--accent-surface);
  }
  .rail-page-item svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* ---- Links ---- */
  .rail-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .rail-link-item {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 8px 12px;
    border-radius: 7px;
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-standard);
  }
  .rail-link-item:hover { background: var(--surface-hover); }

  .rail-link-name {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
  }
  .rail-link-desc {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    line-height: 1.4;
    color: var(--substrate-dim);
  }

  /* ---- Activity ---- */
  .rail-activity {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rail-activity-item {
    display: block;
    padding: 10px 12px;
    border: 1px solid var(--substrate-rule);
    border-radius: 8px;
    background: var(--panel-soft);
    text-decoration: none;
    transition:
      border-color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard);
  }
  .rail-activity-item:hover {
    border-color: var(--accent-line);
    background: var(--surface-hover);
  }

  .rail-activity-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 4px;
  }

  .rail-activity-tag {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--accent);
  }

  .rail-activity-date {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    color: var(--substrate-dim);
  }

  .rail-activity-body {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    line-height: 1.45;
    color: var(--substrate-text);
  }

  /* ---- Commits ---- */
  .rail-commits { gap: 4px; }

  .rail-commit-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 6px;
    align-items: baseline;
    padding: 5px 12px;
    border-radius: 6px;
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-standard);
  }
  .rail-commit-item:hover { background: var(--surface-hover); }

  .rail-commit-sha {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--accent);
  }

  .rail-commit-msg {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--substrate-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ---- Mobile ---- */
  .rail-toggle {
    position: fixed;
    right: 16px;
    bottom: 72px;
    z-index: 81;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--line-soft);
    border-radius: 50%;
    background: var(--surface-button);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--text);
    cursor: pointer;
    box-shadow: var(--shadow-soft);
  }
  .rail-toggle[aria-expanded="true"] { display: none; }
  .rail-toggle svg { width: 20px; height: 20px; }

  @media (max-width: 1099px) {
    .nav-rail {
      transform: translateX(100%);
      transition: transform 0.3s var(--ease-standard);
    }
    .nav-rail[data-open] { transform: translateX(0); }
    .rail-close-btn[hidden] { display: inline-flex !important; }
  }
</style>

<script>
  // ---- Mobile drawer toggle ----
  const rail = document.querySelector<HTMLElement>("[data-nav-rail]");
  const toggle = document.querySelector<HTMLButtonElement>("[data-rail-toggle]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-rail-close]");

  const setOpen = (open: boolean) => {
    if (!rail || !toggle) return;
    if (open) {
      rail.setAttribute("data-open", "");
      toggle.setAttribute("aria-expanded", "true");
    } else {
      rail.removeAttribute("data-open");
      toggle.setAttribute("aria-expanded", "false");
    }
  };

  toggle?.addEventListener("click", () => setOpen(true));
  closeBtn?.addEventListener("click", () => setOpen(false));

  // ---- Theme toggle ----
  const themeToggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");

  const readTheme = () =>
    document.documentElement.dataset.theme === "light" ? "light" : "dark";

  const syncThemeToggle = () => {
    if (themeToggle) {
      const isLight = readTheme() === "light";
      themeToggle.setAttribute("aria-pressed", String(isLight));
      themeToggle.setAttribute(
        "aria-label",
        isLight ? "Switch to dark mode" : "Switch to light mode",
      );
    }
  };

  syncThemeToggle();

  themeToggle?.addEventListener("click", () => {
    const nextTheme = readTheme() === "light" ? "dark" : "light";
    document.documentElement.dataset.theme = nextTheme;
    try {
      localStorage.setItem("cellscript-theme", nextTheme);
    } catch {
      // Theme changes still work even when storage is unavailable.
    }
    syncThemeToggle();
  });

  // ---- Language toggle ----
  const languageToggle = document.querySelector<HTMLButtonElement>("[data-language-toggle]");
  const languageLabel = document.querySelector<HTMLElement>("[data-language-label]");

  // i18n messages are embedded on the home page; on playground we use
  // a simpler toggle that just swaps the dataset and reloads.
  const i18nMessages = (window as any).__CELLSCRIPT_I18N__;
  const defaultLocaleName = (window as any).__CELLSCRIPT_DEFAULT_LOCALE__ ?? "en";

  const readLocale = () =>
    document.documentElement.dataset.locale === "zh" ? "zh" : defaultLocaleName;

  const getMessage = (path: string, locale = readLocale()) => {
    return path.split(".").reduce((value: any, segment: string) => value?.[segment], i18nMessages?.[locale]);
  };

  const applyLocale = (locale: string) => {
    const nextLocale = locale === "zh" ? "zh" : "en";
    document.documentElement.dataset.locale = nextLocale;
    document.documentElement.lang = nextLocale;
    if (i18nMessages) {
      document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((element) => {
        const value = getMessage(element.dataset.i18n ?? "", nextLocale);
        if (typeof value === "string") element.textContent = value;
      });
      document.querySelectorAll<HTMLElement>("[data-i18n-aria-label]").forEach((element) => {
        const value = getMessage(element.dataset.i18nAriaLabel ?? "", nextLocale);
        if (typeof value === "string") element.setAttribute("aria-label", value);
      });
    }
    // Update the toggle's own label
    const switchTo = nextLocale === "zh" ? "EN" : "中文";
    if (languageLabel) languageLabel.textContent = switchTo;
    try {
      localStorage.setItem("cellscript-locale", nextLocale);
    } catch {
      // Language switching still works even when storage is unavailable.
    }
  };

  // Init locale from storage
  try {
    const stored = localStorage.getItem("cellscript-locale");
    if (stored) document.documentElement.dataset.locale = stored;
  } catch {}

  // Update toggle label to show what it switches TO
  const currentLocale = readLocale();
  if (languageLabel) {
    languageLabel.textContent = currentLocale === "zh" ? "EN" : "中文";
  }

  languageToggle?.addEventListener("click", () => {
    // On playground (no i18n messages embedded), reload after toggling
    // so the page re-renders in the new locale.
    if (!i18nMessages) {
      const nextLocale = readLocale() === "en" ? "zh" : "en";
      try {
        localStorage.setItem("cellscript-locale", nextLocale);
      } catch {}
      window.location.reload();
      return;
    }
    applyLocale(readLocale() === "en" ? "zh" : "en");
  });
</script>
