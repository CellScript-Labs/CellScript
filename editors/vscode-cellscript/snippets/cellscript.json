{
  "Action": {
    "prefix": "action",
    "body": [
      "action ${1:name}(${2:input}: ${3:CellType}) -> ${4:output}: ${3:CellType}",
      "where",
      "    require ${5:${4}.owner == ${2}.owner}"
    ],
    "description": "Create a CellScript action with a where proof block"
  },
  "State Transition Action": {
    "prefix": "action-move",
    "body": [
      "action ${1:name}(${2:input}: ${3:CellType}) -> ${4:output}: ${3:CellType}",
      "    move ${2}.${5:state}: ${6:Created} -> ${4}.${5}: ${7:Live}",
      "where",
      "    require ${8:${4}.owner == ${2}.owner}"
    ],
    "description": "Create an action with an explicit state move"
  },
  "Lock": {
    "prefix": "lock",
    "body": [
      "lock ${1:name}(protected ${2:cell}: ${3:CellType}, witness ${4:arg}: ${5:Address}) -> bool {",
      "    require ${6:${4} == ${2}.owner}",
      "}"
    ],
    "description": "Create a CellScript lock with explicit protected/witness boundaries"
  },
  "Resource": {
    "prefix": "resource",
    "body": [
      "resource ${1:Token} {",
      "    ${2:amount}: ${3:u64}",
      "}"
    ],
    "description": "Create a CellScript resource"
  },
  "Shared": {
    "prefix": "shared",
    "body": [
      "shared ${1:Pool} {",
      "    ${2:reserve}: ${3:u64}",
      "}"
    ],
    "description": "Create a CellScript shared state"
  },
  "Receipt": {
    "prefix": "receipt",
    "body": [
      "receipt ${1:Grant} {",
      "    ${2:beneficiary}: ${3:Address}",
      "}"
    ],
    "description": "Create a CellScript receipt"
  },
  "Effect Attribute": {
    "prefix": "effect",
    "body": [
      "#[effect(${1:Pure})]",
      "#[scheduler_hint(${2:parallel}, estimated_cycles = ${3:1000})]"
    ],
    "description": "Insert effect and scheduler hint attributes"
  },
  "Create With Lock": {
    "prefix": "create",
    "body": [
      "create ${1:output} = ${2:Token} {",
      "    ${3:amount}: ${4:1}",
      "} with_lock(${5:owner})"
    ],
    "description": "Constrain a named output with a lock"
  },
  "Move": {
    "prefix": "move",
    "body": [
      "move ${1:input}.${2:state}: ${3:Created} -> ${4:output}.${2}: ${5:Live}"
    ],
    "description": "Declare a field-to-field state transition"
  },
  "Flow": {
    "prefix": "flow",
    "body": [
      "flow ${1:Name} for ${2:Type}.${3:state} {",
      "    ${4:Created} -> ${5:Live};",
      "}"
    ],
    "description": "Declare valid state edges for a state field"
  },
  "Read Parameter": {
    "prefix": "read",
    "body": [
      "read ${1:config}: ${2:Config}"
    ],
    "description": "Declare a read-only action parameter"
  },
  "Witness Parameter": {
    "prefix": "witness",
    "body": [
      "witness ${1:sig}: ${2:Signature}"
    ],
    "description": "Declare a witness-sourced parameter"
  },
  "Require": {
    "prefix": "require",
    "body": [
      "require ${1:condition}"
    ],
    "description": "Fail the current script if a condition is false"
  }
}
