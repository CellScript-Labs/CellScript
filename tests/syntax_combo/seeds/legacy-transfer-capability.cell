// audit: phase=reject_compile
// audit: contains=CS0150
// audit: contains=legacy capability 'transfer'
// audit: contains=replace + relock
module cellscript::audit::seed_legacy_transfer_capability

resource Coin has store, transfer {
    amount: u64,
    nonce: u64,
}

action bad(coin: Coin, to: Address) {
    verification
        transfer coin to to
}
