module cellscript::benchmarks::ickb_limit_order

resource LimitOrder has store, create, consume {
    ckb_amount: u128
    udt_amount: u128
    udt_type_hash: Hash
    ckb_to_udt_ckb_mul: u128
    ckb_to_udt_udt_mul: u128
    udt_to_ckb_ckb_mul: u128
    udt_to_ckb_udt_mul: u128
    ckb_min_match: u128
    master_index: u64
    owner: Address
}

resource OrderMaster has store, create, consume {
    order_index: u64
    owner: Address
}

action mint_order(
    ckb_amount: u128,
    udt_amount: u128,
    udt_type_hash: Hash,
    ckb_to_udt_ckb_mul: u128,
    ckb_to_udt_udt_mul: u128,
    udt_to_ckb_ckb_mul: u128,
    udt_to_ckb_udt_mul: u128,
    ckb_min_match: u128,
    order_index: u64,
    master_index: u64,
    master_relative_distance: i32,
    owner: Address
) -> (LimitOrder, OrderMaster) {
    ckb::require_current_script_args_empty()
    assert_invariant(valid_ratio(ckb_to_udt_ckb_mul, ckb_to_udt_udt_mul), "bad ckb to udt")
    assert_invariant(valid_ratio(udt_to_ckb_ckb_mul, udt_to_ckb_udt_mul), "bad udt to ckb")
    assert_invariant(
        ckb_to_udt_ckb_mul > 0 || udt_to_ckb_ckb_mul > 0,
        "both ratios disabled"
    )
    assert_invariant(ckb_min_match > 0, "zero min match")
    assert_invariant(order_index != master_index, "master overlap")
    ckb::require_metapoint_relative(
        source::output(order_index),
        source::output(master_index),
        master_relative_distance
    )
    ckb::require_lock_type_metapoint_pairs(source::output(0), master_relative_distance)
    ckb::require_lock_type_metapoint_pairs_from_i32_data(source::output(0), 52)

    let order = create LimitOrder {
        ckb_amount,
        udt_amount,
        udt_type_hash,
        ckb_to_udt_ckb_mul,
        ckb_to_udt_udt_mul,
        udt_to_ckb_ckb_mul,
        udt_to_ckb_udt_mul,
        ckb_min_match,
        master_index,
        owner
    } with_lock(owner)

    let master = create OrderMaster {
        order_index,
        owner
    } with_lock(owner)

    (order, master)
}

action fulfill_ckb_to_udt(
    order: LimitOrder,
    new_ckb_amount: u128,
    new_udt_amount: u128,
    owner: Address
) -> LimitOrder {
    ckb::require_current_script_args_empty()
    let role = ckb::current_role()
    let order_capacity = ckb::cell_capacity(source::group_input(0))
    assert_invariant(role == 2, "order fulfilment must run as type script")
    assert_invariant(order_capacity > 0, "missing order input")
    assert_invariant(order.ckb_to_udt_ckb_mul > 0, "ckb to udt disabled")
    assert_invariant(new_ckb_amount < order.ckb_amount, "no ckb paid out")
    assert_invariant(new_udt_amount >= order.udt_amount, "udt decreased")

    c256::require_sum2_products_lte(
        order.ckb_amount, order.ckb_to_udt_ckb_mul,
        order.udt_amount, order.ckb_to_udt_udt_mul,
        new_ckb_amount, order.ckb_to_udt_ckb_mul,
        new_udt_amount, order.ckb_to_udt_udt_mul
    )
    assert_invariant(
        new_ckb_amount == 0 || order.ckb_amount >= new_ckb_amount + order.ckb_min_match,
        "insufficient match"
    )
    ckb::require_lock_match_master_out_point_pairs_from_data(
        source::input(0),
        source::output(0),
        16,
        20,
        52
    )

    consume order

    create LimitOrder {
        ckb_amount: new_ckb_amount,
        udt_amount: new_udt_amount,
        udt_type_hash: order.udt_type_hash,
        ckb_to_udt_ckb_mul: order.ckb_to_udt_ckb_mul,
        ckb_to_udt_udt_mul: order.ckb_to_udt_udt_mul,
        udt_to_ckb_ckb_mul: order.udt_to_ckb_ckb_mul,
        udt_to_ckb_udt_mul: order.udt_to_ckb_udt_mul,
        ckb_min_match: order.ckb_min_match,
        master_index: order.master_index,
        owner
    } with_lock(owner)
}

action fulfill_udt_to_ckb(
    order: LimitOrder,
    new_ckb_amount: u128,
    new_udt_amount: u128,
    owner: Address
) -> LimitOrder {
    ckb::require_current_script_args_empty()
    let role = ckb::current_role()
    let order_capacity = ckb::cell_capacity(source::group_input(0))
    assert_invariant(role == 2, "order fulfilment must run as type script")
    assert_invariant(order_capacity > 0, "missing order input")
    assert_invariant(order.udt_to_ckb_ckb_mul > 0, "udt to ckb disabled")
    assert_invariant(new_udt_amount < order.udt_amount, "no udt paid out")
    assert_invariant(new_ckb_amount >= order.ckb_amount, "ckb decreased")

    c256::require_sum2_products_lte(
        order.ckb_amount, order.udt_to_ckb_ckb_mul,
        order.udt_amount, order.udt_to_ckb_udt_mul,
        new_ckb_amount, order.udt_to_ckb_ckb_mul,
        new_udt_amount, order.udt_to_ckb_udt_mul
    )
    assert_invariant(
        new_udt_amount == 0 ||
            order.udt_amount * order.udt_to_ckb_udt_mul >=
                new_udt_amount * order.udt_to_ckb_udt_mul +
                    order.ckb_min_match * order.udt_to_ckb_ckb_mul,
        "insufficient match"
    )
    ckb::require_lock_match_master_out_point_pairs_from_data(
        source::input(0),
        source::output(0),
        16,
        20,
        52
    )

    consume order

    create LimitOrder {
        ckb_amount: new_ckb_amount,
        udt_amount: new_udt_amount,
        udt_type_hash: order.udt_type_hash,
        ckb_to_udt_ckb_mul: order.ckb_to_udt_ckb_mul,
        ckb_to_udt_udt_mul: order.ckb_to_udt_udt_mul,
        udt_to_ckb_ckb_mul: order.udt_to_ckb_ckb_mul,
        udt_to_ckb_udt_mul: order.udt_to_ckb_udt_mul,
        ckb_min_match: order.ckb_min_match,
        master_index: order.master_index,
        owner
    } with_lock(owner)
}

action cancel_order(order: LimitOrder, master: OrderMaster, owner: Address) {
    ckb::require_current_script_args_empty()
    assert_invariant(order.owner == owner, "wrong owner")
    assert_invariant(master.owner == owner, "wrong master owner")

    consume order
    consume master
}

fn valid_ratio(ckb_mul: u128, udt_mul: u128) -> bool {
    (ckb_mul == 0 && udt_mul == 0) || (ckb_mul > 0 && udt_mul > 0)
}

lock order_owner(order: protected LimitOrder, claimed_owner: witness Address) -> bool {
    ckb::require_current_script_args_empty()
    require ckb::current_role() == 1
    require order.owner == claimed_owner
}

// TODO(ickb-benchmark): CellScript now has executable C256 product-sum
// requirement helpers for the core price-conservation check and a pairwise
// MetaPoint relative-distance helper for mint-time order/master linkage. It
// also has executable current-script lock-only/type-only pair cardinality for
// fixed-distance mint paths and an i32-data-offset bridge for the original
// mint action's master-distance bytes. Match paths can now require lock-only
// order cells to preserve the same master OutPoint when outputs encode
// Action::Match with absolute master bytes. It still has no first-class C256
// value type, native protocol-specific MetaPoint map, or full Script object
// for "same script as lock in the order cell and as type in the master cell".
